# ─── DATABASE ────────────────────────────────────────────────────────────────
# Production / Vercel — get a free PostgreSQL URL from Neon (https://neon.tech)
# or Supabase (https://supabase.com) or Railway (https://railway.app)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/training_dashboard?sslmode=require"

# Local development — copy this file to .env.local and replace with your own URL
# You can also use a local Neon branch for local dev (recommended)

# ─── APP ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_NAME="Learning Intelligence Dashboard"
