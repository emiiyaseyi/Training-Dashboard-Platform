generator client {
  provider = "prisma-client-js"
}

datasource db {
  // LOCAL DEV: SQLite (file:./prisma/dev.db in .env.local)
  // VERCEL:    The build script replaces "sqlite" with "postgresql" automatically
  //            Set DATABASE_URL in Vercel environment variables.
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model BusinessUnit {
  id         String   @id @default(cuid())
  name       String   @unique
  budget     Float    @default(0)
  staffCount Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model UploadBatch {
  id          String   @id @default(cuid())
  type        String
  filename    String
  recordCount Int
  period      String?
  createdAt   DateTime @default(now())

  trainingRecords     TrainingRecord[]
  feedbackRecords     FeedbackRecord[]
  subscriptionRecords SubscriptionRecord[]
}

model TrainingRecord {
  id           String   @id @default(cuid())
  serialNo     String?
  staffName    String
  staffId      String
  training     String
  businessUnit String
  month        String
  year         Int
  cost         Float
  batchId      String
  createdAt    DateTime @default(now())

  batch UploadBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)

  @@index([businessUnit])
  @@index([year])
  @@index([staffId])
}

model FeedbackRecord {
  id                  String   @id @default(cuid())
  businessUnit        String
  trainingTitle       String
  role                String?
  applicationResponse String?
  impactAlignment     String?
  confidenceRating    Float?
  roleRelevance       Float?   // "How relevant is this training to your role?" (1–5)
  expectationsMet     Float?   // "To what extent were your expectations met?" (1–5)
  qualitativeResponse String?
  month               String?
  batchId             String
  createdAt           DateTime @default(now())

  batch UploadBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)

  @@index([businessUnit])
}

model SubscriptionRecord {
  id             String   @id @default(cuid())
  month          String?
  staffId        String
  staffName      String
  businessUnit   String
  membershipOrg  String
  amount         Float
  batchId        String
  createdAt      DateTime @default(now())

  batch UploadBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)

  @@index([businessUnit])
  @@index([membershipOrg])
  @@index([staffId])
}

model HistoricalSnapshot {
  id        String   @id @default(cuid())
  period    String
  type      String
  data      String
  createdAt DateTime @default(now())

  @@unique([period, type])
}

model NarrativeReport {
  id        String   @id @default(cuid())
  period    String
  content   String
  type      String
  createdAt DateTime @default(now())
}
